  "paths": {
    "/api/v1/world/zones": {
      "get": {
        "tags": [
          "world-monitor-controller"
        ],
        "summary": "Get all world zones",
        "operationId": "getAllZones",
        "responses": {
          "200": {
            "description": "Successfully retrieved zones",
            "headers": {
              "X-Sim-Tick": {
                "description": "Current simulation tick",
                "style": "simple",
                "schema": {
                  "type": "integer"
                }
              }
            },
            "content": {
              "*/*": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ZoneDto"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/world/zones/{id}": {
      "get": {
        "tags": [
          "world-monitor-controller"
        ],
        "summary": "Get zone details",
        "operationId": "getZoneDetail",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Zone unique identifier",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successfully retrieved zone details",
            "headers": {
              "X-Sim-Tick": {
                "description": "Current simulation tick",
                "style": "simple",
                "schema": {
                  "type": "integer"
                }
              }
            },
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ZoneDto"
                }
              }
            }
          },
          "404": {
            "description": "Zone not found",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ZoneDto"
                }
              }
            }
          }
        }
      }
    },
