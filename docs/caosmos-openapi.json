  "components": {
    "schemas": {
      "Vector3": {
        "type": "object",
        "properties": {
          "x": {
            "type": "number",
            "format": "double"
          },
          "y": {
            "type": "number",
            "format": "double"
          },
          "z": {
            "type": "number",
            "format": "double"
          }
        }
      },
      "ZoneDto": {
        "type": "object",
        "description": "Detailed representation of a world zone",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier of the zone"
          },
          "name": {
            "type": "string",
            "description": "Name of the zone"
          },
          "parentZoneId": {
            "type": "string",
            "description": "Parent zone identifier if nested"
          },
          "type": {
            "type": "string",
            "description": "Type of the zone (INTERIOR/EXTERIOR)",
            "enum": [
              "EXTERIOR",
              "INTERIOR",
              "UNKNOWN"
            ]
          },
          "isEntryRestricted": {
            "type": "boolean",
            "description": "Whether the zone requires specific entry points"
          },
          "category": {
            "type": "string",
            "description": "Category of the zone"
          },
          "owned": {
            "type": "string",
            "description": "Name of the owner, or null if unowned"
          },
          "tags": {
            "type": "array",
            "description": "Semantic tags associated with the zone",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "center": {
            "$ref": "#/components/schemas/Vector3",
            "description": "Center coordinates"
          },
          "width": {
            "type": "number",
            "format": "double",
            "description": "Width of the zone (X-axis)"
          },
          "length": {
            "type": "number",
            "format": "double",
            "description": "Length of the zone (Z-axis)"
          }
        }
      },
