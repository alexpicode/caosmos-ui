            "$ref": "#/components/schemas/CitizenConfigDto",
            "description": "Citizen configuration profile"
          },
          "perception": {
            "$ref": "#/components/schemas/CitizenPerception",
            "description": "Citizen's current perception of the world"
          },
          "currentAction": {
