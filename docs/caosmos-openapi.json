        "type": "object",
        "description": "Summary representation of a world entity",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier of the entity"
          },
          "type": {
            "type": "string",
            "description": "Type of the entity (e.g. OBJECT, ZONE)",
            "enum": [
              "OBJECT",
              "CITIZEN",
              "ZONE",
              "SPEECH"
            ]
          },
          "displayName": {
            "type": "string",
            "description": "Display name of the entity"
          },
          "description": {
            "type": "string",
            "description": "Detailed description"
          },
          "category": {
            "type": "string",
            "description": "Category of the entity"
          },
          "owned": {
            "type": "string",
            "description": "Name of the owner, or null if unowned"
          },
          "tags": {
            "type": "array",
            "description": "Semantic tags associated with the entity",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "x": {
            "type": "number",
            "format": "double",
            "description": "X coordinate"
          },
          "y": {
            "type": "number",
            "format": "double",
            "description": "Y coordinate"
          },
          "z": {
            "type": "number",
            "format": "double",
            "description": "Z coordinate"
          }
        }
      },
      "WorldObjectDetailDto": {
        "type": "object",
        "description": "Detailed representation of a world object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier of the object"
          },
          "type": {
            "type": "string",
            "description": "Type of the entity",
            "enum": [
              "OBJECT",
              "CITIZEN",
              "ZONE",
              "SPEECH"
            ]
          },
          "name": {
            "type": "string",
            "description": "Name of the object"
          },
          "description": {
            "type": "string",
            "description": "Detailed description"
          },
          "category": {
            "type": "string",
            "description": "Category of the object"
          },
          "owned": {
            "type": "string",
            "description": "Name of the owner, or null if unowned"
          },
          "tags": {
            "type": "array",
            "description": "Semantic tags associated with the object",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "parentZoneId": {
            "type": "string",
            "description": "ID of the zone this object is located in"
          },
          "targetZoneId": {
            "type": "string",
            "description": "ID of the zone this gateway leads to (if applicable)"
          },
          "position": {
            "$ref": "#/components/schemas/Vector3",
            "description": "Position in the world"
          },
          "radius": {
            "type": "number",
            "format": "double",
            "description": "Circular collision radius"
          },
          "width": {
            "type": "number",
            "format": "double",
            "description": "Rectangular collision width"
          },
          "length": {
            "type": "number",
            "format": "double",
            "description": "Rectangular collision length"
          },
          "amount": {
            "type": "number",
            "format": "double",
            "description": "Quantity or amount"
          }
        }
      },
      "Environment": {
        "type": "object",
        "properties": {
          "terrainType": {
            "type": "string"
          },
          "tags": {
            "type": "array",
